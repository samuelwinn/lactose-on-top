rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string;
    }

    function isValidChat(data) {
      return data.type in ['dm', 'group'] && data.participants is list;
    }

    function isValidMessage(data) {
      return data.chatId is string && data.senderId is string && data.text is string && data.text.size() < 1000;
    }

    function isValidTCGUser(data) {
      return data.collection is map && (data.lastPackOpened == null || data.lastPackOpened is timestamp);
    }

    // User Profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && isValidUser(request.resource.data);
    }

    // TCG Collections
    match /tcg_users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && isValidTCGUser(request.resource.data);
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data);
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && request.auth.uid == request.resource.data.senderId && isValidMessage(request.resource.data);
      }
    }
  }
}
